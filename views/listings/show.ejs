<%- layout("layouts/boilerplate") %>

<script>
  const mapToken = "<%= process.env.MAP_TOKEN %>";
  const coordinates = <%- JSON.stringify(listing.geometry.coordinates) %>;
</script>
<div class="row mt-3">

  <!-- Listing Card -->
  <div class="col-lg-6 col-md-8 col-sm-10 mx-auto">

    <div class="card show-card listing-card">

      <img src="<%= listing.image.url %>" class="card-img-top show-img">

      <div class="card-body">

        <p>Owned by <i><%= listing.owner.username %></i></p>

        <p><%= listing.description %></p>

        <p>₹<%= listing.price.toLocaleString("en-IN") %></p>

        <p><%= listing.location %></p>

        <p><%= listing.country %></p>

        <% if(currUser && listing.owner._id.equals(currUser._id)) { %>

        <div class="d-flex gap-2 mb-3">

          <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark">
            Edit
          </a>

          <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">

            <button class="btn btn-danger">
              Delete
            </button>

          </form>

        </div>

        <% } %>

        <hr>

        <!-- Review Form -->

        <% if(currUser) { %>

        <h4>Leave a Review</h4>

        <form action="/listings/<%= listing._id %>/reviews" method="POST" class="needs-validation" novalidate>

          <label class="form-label">Rating</label>

          <fieldset class="starability-slot">

            <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked>

            <input type="radio" id="slot-rate1" name="review[rating]" value="1">
            <label for="slot-rate1">1</label>

            <input type="radio" id="slot-rate2" name="review[rating]" value="2">
            <label for="slot-rate2">2</label>

            <input type="radio" id="slot-rate3" name="review[rating]" value="3">
            <label for="slot-rate3">3</label>

            <input type="radio" id="slot-rate4" name="review[rating]" value="4">
            <label for="slot-rate4">4</label>

            <input type="radio" id="slot-rate5" name="review[rating]" value="5">
            <label for="slot-rate5">5</label>

          </fieldset>

          <div class="mb-3 mt-2">

            <label class="form-label">Comments</label>

            <textarea
              name="review[comment]"
              rows="3"
              class="form-control"
              required
            ></textarea>

            <div class="invalid-feedback">
              Please add some comments for review
            </div>

          </div>

          <button class="btn btn-outline-dark">
            Submit
          </button>

        </form>

        <hr>

        <% } %>

        <!-- All Reviews -->

        <% if(listing.reviews.length > 0) { %>

        <p><b>All Reviews</b></p>

        <div class="row">

          <% for(let review of listing.reviews) { %>

          <div class="col-md-6 mb-3">

            <div class="card">

              <div class="card-body review-card">

                <div class="d-flex justify-content-between">

                  <p>@<%= review.author.username %></p>

                  <p class="starability-result" data-rating="<%= review.rating %>"></p>

                </div>

                <p class="review-comment">
                  <%= review.comment %>
                </p>

                <% if(currUser && review.author._id.equals(currUser._id)) { %>

                <form
                  method="POST"
                  action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
                >

                  <button class="btn btn-sm btn-dark">
                    Delete
                  </button>

                </form>

                <% } %>

              </div>

            </div>

          </div>

          <% } %>

        </div>

        <% } %>

      </div>

    </div>

  </div>

</div>

<!-- Map Section -->

<div class="row">

  <div class="col-lg-6 col-md-8 col-sm-10 mx-auto mb-4">

    <h3 class="text-center">Where you'll be</h3>

    <div id="map"></div>

  </div>

</div>

<script src="/js/map.js"></script>